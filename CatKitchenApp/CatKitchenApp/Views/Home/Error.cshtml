@model ErrorViewModel
@{
    ViewData["Title"] = "Ой, что-то пошло не так!";
}

<div class="container mt-5 text-center">
    <div class="mb-4">
        <i class="bi bi-cone-striped text-warning" style="font-size: 5rem;"></i>
    </div>
    <h1 class="text-danger fw-bold">Упс! Произошла ошибка.</h1>
    <p class="fs-5 text-muted">Мы уже знаем о проблеме и наши лучшие коты-программисты чинят её.</p>

    @if (Model.ShowRequestId)
    {
        <p class="text-secondary mt-3">
            <small>ID запроса для поддержки: <code>@Model.RequestId</code></small>
        </p>
    }

    <div class="mt-4">
        <a asp-controller="Recipes" asp-action="Index" class="btn btn-primary"><i class="bi bi-house-door"></i> Вернуться к рецептам</a>
    </div>
</div>