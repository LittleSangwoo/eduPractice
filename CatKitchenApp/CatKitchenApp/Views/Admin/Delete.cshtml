@model CatKitchenApp.Models.Recipe
@{
    ViewData["Title"] = "Удаление рецепта";
}

<div class="container mt-5 text-center">
    <div class="card shadow-sm border-danger mx-auto" style="max-width: 500px;">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Подтверждение удаления</h4>
        </div>
        <div class="card-body">
            <p class="fs-5">Вы уверены, что хотите удалить рецепт:</p>
            <h3 class="fw-bold text-dark">"@Model.RecipeName"?</h3>
            <p class="text-muted">Это действие нельзя отменить.</p>

            <form asp-action="Delete" method="post" class="mt-4">
                <input type="hidden" asp-for="RecipeID" />
                <a asp-action="Index" class="btn btn-secondary">Отмена</a>
                <button type="submit" class="btn btn-danger px-4">Да, удалить</button>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}