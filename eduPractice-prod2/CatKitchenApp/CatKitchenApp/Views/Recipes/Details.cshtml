@model CatKitchenApp.Models.Recipe
@{
    ViewData["Title"] = Model.RecipeName;
}

<div class="container mt-4">
    <a asp-action="Index"  class="btn btn-primary btn-sm rounded-pill px-3" style="margin-bottom: 10px">
        <i class="bi bi-eye"></i> Назад
    </a>

    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-4">
                <img src="@Model.Image" class="img-fluid" alt="@Model.RecipeName">
                <div class="card-body">
                    <h4 class="fw-bold">@Model.RecipeName</h4>
                    <p class="text-muted">@Model.Description</p>
                    <hr>
                    <div class="d-flex justify-content-between mb-2">
                        <span><i class="bi bi-clock"></i> Время:</span>
                        <span class="fw-bold">@Model.CookingTime мин.</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span><i class="bi bi-tag"></i> Категория:</span>
                        <span class="badge bg-primary">@Model.Category?.CategoryName</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4 p-4 mb-4">
                <h5 class="fw-bold border-bottom pb-2 text-primary">Ингредиенты</h5>
                <ul class="list-group list-group-flush mb-4">
                    @foreach (var ing in Model.RecipeIngredients)
                    {
                        <li class="list-group-item">
                            @ing.Ingredient?.IngredientName — @ing.Quantity
                        </li>
                    }
                </ul>

                <h5 class="fw-bold border-bottom pb-2 text-primary">Способ приготовления</h5>
                <div class="mt-3">
                    @foreach (var step in Model.CookingSteps)
                    {
                        <div class="d-flex mb-3">
                            <div class="flex-shrink-0">
                                <span class="badge bg-primary rounded-circle p-2" style="width: 30px; height: 30px; display: inline-block;">@step.StepNumber</span>
                            </div>
                            <div class="ms-3">
                                @step.StepDescription
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-4 p-4">
                <h5 class="fw-bold border-bottom pb-2 text-primary">Отзывы пушистых критиков</h5>
                @foreach (var review in Model.Reviews)
                {
                    <div class="border-start border-4 border-info ps-3 my-3">
                        <div class="text-warning">
                            @for (int i = 0; i < review.Rating; i++)
                            {
                                <i class="bi bi-star-fill"></i>
                            }
                        </div>
                        <p class="fst-italic">"@review.ReviewText"</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>