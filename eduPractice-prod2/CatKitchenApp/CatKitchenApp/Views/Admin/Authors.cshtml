@model IEnumerable<CatKitchenApp.Models.Author>
@{
    ViewData["Title"] = "Авторы";
}

<div class="container mt-4">
    <h3 class="fw-bold text-danger mb-3"><i class="bi bi-people"></i> Справочник: Авторы</h3>
    <partial name="_AdminNav" />

    <div class="card shadow-sm border-0 rounded-3">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Имя автора</th>
                    <th>Логин</th>
                    <th>Email</th>
                    <th>Роль</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.AuthorID</td>
                        <td class="fw-semibold">@item.AuthorName</td>
                        <td>@item.Login</td>
                        <td>@item.Mail</td>
                        <td><span class="badge bg-secondary">@item.Role.RoleName</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>