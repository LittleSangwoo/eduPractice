@model IEnumerable<CatKitchenApp.Models.Category>
@{ ViewData["Title"] = "Категории"; }

<div class="container mt-4">
    <h3 class="fw-bold text-danger mb-3"><i class="bi bi-grid"></i> Справочник: Категории</h3>
    <partial name="_AdminNav" />

    <div class="card shadow-sm border-0 rounded-3">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr><th>ID</th><th>Название категории</th></tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr><td>@item.CategoryID</td><td class="fw-semibold">@item.CategoryName</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>