@model CatKitchenApp.ViewModels.RecipeFormViewModel

@{
    ViewData["Title"] = "Редактирование рецепта";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Редактирование рецепта</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="RecipeID" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="RecipeName" class="form-label fw-bold"></label>
                            <input asp-for="RecipeName" class="form-control" placeholder="Например: Рагу из кролика" />
                            <span asp-validation-for="RecipeName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold"></label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Краткое описание блюда..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="CookingTime" class="form-label fw-bold"></label>
                                <div class="input-group">
                                    <input asp-for="CookingTime" class="form-control" type="number" />
                                    <span class="input-group-text">мин</span>
                                </div>
                                <span asp-validation-for="CookingTime" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="CategoryID" class="form-label fw-bold"></label>
                                <select asp-for="CategoryID" asp-items="Model.Categories" class="form-select">
                                    <option value="">-- Выберите категорию --</option>
                                </select>
                                <span asp-validation-for="CategoryID" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="AuthorID" class="form-label fw-bold"></label>
                                <select asp-for="AuthorID" asp-items="Model.Authors" class="form-select">
                                    <option value="">-- Выберите автора --</option>
                                </select>
                                <span asp-validation-for="AuthorID" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Image" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-image"></i></span>
                                <input asp-for="Image" class="form-control" placeholder="/images/example.jpg" />
                            </div>
                            <div class="form-text text-muted">Укажите путь к изображению или URL.</div>
                            <span asp-validation-for="Image" class="text-danger small"></span>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Image))
                        {
                            <div class="mb-4 p-2 border rounded bg-light text-center">
                                <p class="small text-muted mb-1">Текущее изображение:</p>
                                <img src="@Model.Image" alt="Preview" style="max-height: 150px; border-radius: 5px;" />
                            </div>
                        }

                        <div class="d-flex justify-content-between pt-2 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4"><i class="bi bi-arrow-left"></i> Назад</a>
                            <button type="submit" class="btn btn-primary px-4"><i class="bi bi-save"></i> Сохранить изменения</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}