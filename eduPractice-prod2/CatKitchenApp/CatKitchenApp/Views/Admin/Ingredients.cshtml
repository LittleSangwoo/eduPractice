@model IEnumerable<CatKitchenApp.Models.Ingredient>
@{
    ViewData["Title"] = "Ингредиенты";
}

<div class="container mt-4">
    <h3 class="fw-bold text-danger mb-3"><i class="bi bi-basket"></i> Справочник: Ингредиенты</h3>
    <partial name="_AdminNav" />

    <div class="card shadow-sm border-0 rounded-3">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr><th>ID</th><th>Название ингредиента</th></tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr><td>@item.IngredientID</td><td class="fw-semibold">@item.IngredientName</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>