@model CatKitchenApp.ViewModels.RecipeIndexViewModel
@{
    ViewData["Title"] = "Панель администратора";
}
<style>
    footer, .footer, .border-top.footer.text-muted {
        position: static !important; /* Сбрасываем absolute */
        bottom: auto !important;
        margin-top: auto !important; /* Прижимает футер к самому низу flex-контейнера */
        width: 100% !important;
        background-color: #fae8d6 !important; /* В цвет нашего стиля */
        border: none !important;
        border-top: 2px solid #f0d5be !important;
        color: #8d6e63 !important;
        padding: 20px 0 !important;
        line-height: normal !important;
    }

        /* Скрываем стандартные ссылки в футере, чтобы они не ломали цвет, если нужно */
        footer a {
            color: #d35400 !important;
            text-decoration: none;
        }
</style>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-danger"><i class="bi bi-shield-lock"></i> Управление рецептами</h2>
        <partial name="_AdminNav" />
        <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-lg"></i> Добавить рецепт</a>
    </div>

    <div class="card shadow-sm border-0 mb-4 rounded-3">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-md-5">
                    <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Поиск...">
                </div>
                <div class="col-md-4">
                    <select name="categoryId" asp-items="Model.Categories" class="form-select">
                        <option value="">-- Все категории --</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label text-muted small mb-1">Сортировка</label>
                    <select name="sortOrder" class="form-select bg-light">
                        <option value="" selected="@(string.IsNullOrEmpty(Model.SortOrder))">По названию (А-Я)</option>
                        <option value="name_desc" selected="@(Model.SortOrder == "name_desc")">По названию (Я-А)</option>
                        <option value="time" selected="@(Model.SortOrder == "time")">Сначала быстрые</option>
                        <option value="time_desc" selected="@(Model.SortOrder == "time_desc")">Сначала долгие</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100">Применить</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Сброс</a>
                </div>
            </form>
        </div>
    </div>
    @if (!Model.Recipes.Any())
    {
        <div class="text-center py-5">
            <h3 class="text-muted">Ничего не найдено</h3>
            <p>Попробуйте изменить параметры поиска</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
            <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                <table class="table table-hover align-middle mb-0 ">
                    <thead class="table-dark sticky-top" style="z-index: 1;">
                        <tr>
                            <th class="ps-3">Фото</th>
                            <th>
                                <a asp-action="Index"
                                   asp-route-sortOrder="@ViewData["NameSort"]"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-categoryId="@Model.SelectedCategoryId"
                                   class="text-white text-decoration-none">
                                    Название <i class="bi bi-arrow-down-up small"></i>
                                </a>
                            </th>
                            <th>Категория</th>
                            <th>
                                <a asp-action="Index"
                                   asp-route-sortOrder="@ViewData["TimeSort"]"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-categoryId="@Model.SelectedCategoryId"
                                   class="text-white text-decoration-none">
                                    Время <i class="bi bi-arrow-down-up small"></i>
                                </a>
                            </th>
                            <th class="text-end pe-3">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Recipes)
                        {
                            <tr>
                                <td class="ps-3">
                                    <div class="img-container shadow-sm border rounded" style="width: 80px; height: 80px; overflow: hidden;">
                                        <img src="@(string.IsNullOrEmpty(item.Image) ? "/images/placeholder.jpg" : item.Image)"
                                             alt="@item.RecipeName"
                                             style="width: 100%; height: 100%; object-fit: cover;">
                                    </div>
                                </td>
                                <td class="fw-semibold">@item.RecipeName</td>
                                <td>@item.Category?.CategoryName</td>
                                <td>@item.CookingTime мин.</td>
                                <td class="text-end pe-3">
                                    <a asp-action="Edit" asp-route-id="@item.RecipeID" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> Изменить</a>
                                    <a asp-action="Delete" asp-route-id="@item.RecipeID" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Удалить</a>
                                    <a asp-controller="Admin" asp-action="Details" asp-route-id="@item.RecipeID" class="btn btn-sm btn-outline-info">
                                        <i class="bi bi-eye"></i>Посмотреть
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    
</div>